{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/netzkontrast/agency/maintenance/schemas/l2-task.schema.json",
  "title": "L1 + task_* L2 namespace",
  "description": "Mirror of header-ontology.json types.task. Generated by tools/fm/gen_schema_mirror.py — do not edit by hand.",
  "type": "object",
  "properties": {
    "type": {
      "const": "task"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "blocked",
        "completed",
        "archived"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "task_status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "blocked",
        "done",
        "updated",
        "abandoned"
      ]
    },
    "task_owner": {
      "type": "string"
    },
    "task_priority": {
      "type": "string",
      "enum": [
        "P0",
        "P1",
        "P2",
        "P3"
      ]
    },
    "task_uses_prompts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_spawns_research": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_spawns_prompts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_affects_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_blocked_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "task_superseded_by": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "type",
    "status",
    "slug",
    "summary",
    "created",
    "updated",
    "task_id",
    "task_status",
    "task_owner",
    "task_priority",
    "task_uses_prompts",
    "task_spawns_research",
    "task_spawns_prompts",
    "task_affects_paths"
  ],
  "additionalProperties": true
}
