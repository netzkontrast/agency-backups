{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/netzkontrast/agency/maintenance/schemas/l1-vault-core.schema.json",
  "title": "L1 Vault Core frontmatter (mandatory for operational files)",
  "description": "Mirror of header-ontology.json `l1_required`. Generated by tools/fm/gen_schema_mirror.py — do not edit by hand.",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "task",
        "prompt",
        "research",
        "spec",
        "readme",
        "note",
        "index",
        "skill",
        "adr"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "blocked",
        "completed",
        "archived"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    }
  },
  "required": [
    "type",
    "status",
    "slug",
    "summary",
    "created",
    "updated"
  ],
  "additionalProperties": true
}
