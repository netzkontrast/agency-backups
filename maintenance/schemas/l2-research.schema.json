{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/netzkontrast/agency/maintenance/schemas/l2-research.schema.json",
  "title": "L1 + research_* L2 namespace",
  "description": "Mirror of header-ontology.json types.research. Generated by tools/fm/gen_schema_mirror.py — do not edit by hand.",
  "type": "object",
  "properties": {
    "type": {
      "const": "research"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "blocked",
        "completed",
        "archived"
      ]
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "created": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "research_phase": {
      "type": "string"
    },
    "research_executes_prompt": {
      "type": "string"
    },
    "research_friction_level": {
      "type": "string"
    }
  },
  "required": [
    "type",
    "status",
    "slug",
    "summary",
    "created",
    "updated",
    "research_phase",
    "research_executes_prompt",
    "research_friction_level"
  ],
  "additionalProperties": true
}
