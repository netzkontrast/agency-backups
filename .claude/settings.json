{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level Claude Code config for the agency repo. Authored by Task 094 ST-2 per docs.anthropic.com/en/docs/claude-code/settings. The .claude/skills/ symlink points at ../skills/ so all 54 imported skills (39 sc-* + 15 superpowers-*) plus the in-repo non-imported skills load at session start. Task 094 ST-3 populated the hooks block with 5 D.7-compliant event hooks (UserPromptSubmit / PreToolUse / PostToolUse / Stop / SubagentStop) — ADR-0011 D.7 forbids session-start-hook injection; that event is intentionally absent (the test reads the hooks block JSON, not the prose).",
  "skillListingBudgetFraction": 0.05,
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/tools/hooks/user-prompt-submit.sh", "args": [] }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Skill|Agent",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/tools/hooks/pre-tool-use.sh", "args": [] }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill|Agent",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/tools/hooks/post-tool-use.sh", "args": [] }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/tools/hooks/stop.sh", "args": [] }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "code-reviewer|deep-research",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/tools/hooks/subagent-stop.sh", "args": [] }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "TodoWrite",
      "NotebookEdit"
    ],
    "deny": []
  }
}
