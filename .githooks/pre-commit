#!/usr/bin/env bash
# Pre-commit hook for the agency repository.
# Defers to tools/check-governance.sh (Task 017 cutover): fm-validate is
# the canonical frontmatter linter; tools/legacy/lint-{structure,linkage}.py
# still gate on structural and cross-ref rules until they fold into fm-*.
# A delta-aware mode is a follow-up; pre-commit currently runs the full suite.
#
# Install once per clone:
#   git config core.hooksPath .githooks

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

PYTHON="${PYTHON:-python3}"
export FM_LEGACY_QUIET=1

if "$PYTHON" -c "import sys; sys.exit(0)" >/dev/null 2>&1; then
  :
fi

echo "=== agency pre-commit ==="
if bash tools/check-governance.sh; then
  echo "=== All governance linters passed. ==="
  exit 0
fi

if "$PYTHON" tools/check-maintenance-bypass.py; then
  echo "=== WARNING: Governance linters failed, but all errors are covered by open Tasks. Maintenance bypass active. ==="
  ${EXIT_CMD:-exit} 0
fi

echo "=== BLOCKED: one or more governance linters failed and are not covered by open Tasks. Fix all ERRORs before committing. ==="
${EXIT_CMD:-exit} 1
