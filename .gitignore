__pycache__/
*.pyc
.agent_cache/

# Task 094 ST-2: .claude/ holds the project-level Claude Code config
# (settings.json + skills symlink + agents re-exports + plugin assets).
# It MUST be tracked. Only the worktrees scratch path is ignored.
.claude/worktrees/

# pytest-cov / pytest-benchmark transient artefacts
.coverage
.coverage.*
.pytest_cache/
.benchmarks/

# ADR-0007: skill_bundles_tools materialisation produced by
# skills/skills-skill-bootstrap/sync.sh under ~/.claude/skills/<name>/.
# Defensive ignore for the in-repo path so accidental git-adds never
# capture a bundled tool tree.
skills/*/scripts/_bundled/

# Task 094 ST-3: skill-invocation telemetry log auto-generated by
# tools/hooks/pre-tool-use.sh + post-tool-use.sh. Non-normative per
# the file's own banner; safe to delete between task closures.
tasks/*/skill-invocation-log.md
